{
  "name": "asmlift-workspace",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "description": "asmlift monorepo: @asmlift/core (pure decompiler), @asmlift/cli (toolchains + scoring + bin), apps (benchmark, web).",
  "packageManager": "pnpm@9.14.4",
  "scripts": {
    "asmlift": "tsx packages/cli/src/main.ts",
    "test": "vitest run && vitest run --config vitest.matching.config.ts",
    "test:offline": "vitest run packages/core/test packages/cli/test/offline",
    "test:matching": "vitest run --config vitest.matching.config.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p packages/core",
    "bench": "tsx apps/benchmark/src/cli.ts",
    "bench:merge": "tsx apps/benchmark/src/cli.ts merge",
    "bench:smoke": "tsx apps/benchmark/src/cli.ts smoke",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2",
    "vitest": "^3.2.0"
  },
  "dependencies": {
    "@asmlift/cli": "workspace:*"
  }
}
