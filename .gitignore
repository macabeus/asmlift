# dependencies / build
node_modules/
dist/
build/
.npmrc

# toolchain / scoring scratch + OS cruft
*.o
# ...except the committed scorer fixtures (objdiff.test.ts scores these offline in CI)
!packages/cli/test/offline/fixtures/objdiff/*.o
*.elf
*.gba
.DS_Store

# benchmark run logs (noise); the merged results.json + report data ARE committed
apps/benchmark/results/*.log
# per-worker partials written mid-run then merged into synthetic.json (transient)
apps/benchmark/results/*.part*.json
# CI-fetched toolchains + pinned m2c (.github/workflows/benchmark.yml)
.deps/
# per-tier intermediates regenerated by every `bench run` (results.json stays committed)
apps/benchmark/results/synthetic.json
apps/benchmark/results/real.json
*.tsbuildinfo
apps/benchmark/.cache/
_site/

# local Claude Code state
.claude/
research/
packages/cli/dist/
